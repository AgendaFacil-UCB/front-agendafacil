<div class="container">
    <div class="row">
        <div class="col-md-12">
            <h1>Serviços Disponíveis</h1>
            <p class="lead">Encontre e agende os serviços que você procura</p>

            {{#services}}
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <h5 class="card-title">{{name}}</h5>
                                <p class="card-text">{{description}}</p>
                                <small class="text-muted">
                                    <strong>Prestador:</strong> {{prestador_name}}<br>
                                    <strong>Categoria:</strong> {{category_name}}<br>
                                    <strong>Duração:</strong> {{duration}} minutos
                                </small>
                            </div>
                            <div class="col-md-4 text-end">
                                <h4 class="text-success mb-3">R$ {{price}}</h4>
                                <a href="/services/{{id}}" class="btn btn-primary">Ver Detalhes</a>
                            </div>
                        </div>
                    </div>
                </div>
            {{/services}}

            {{^services}}
                <div class="alert alert-info">
                    Nenhum serviço disponível no momento.
                </div>
            {{/services}}
        </div>
    </div>
</div>

