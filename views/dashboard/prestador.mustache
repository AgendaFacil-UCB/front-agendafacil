<div class="container">
    <div class="row">
        <div class="col-md-8">
            <h1>Dashboard do Prestador</h1>
            <p>Bem-vindo, {{user.name}}!</p>

            <div class="row">
                <div class="col-md-6">
                    <div class="card text-center mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Serviços Cadastrados</h5>
                            <h2 class="text-success">{{totalServices}}</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card text-center mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Total de Agendamentos</h5>
                            <h2 class="text-info">{{totalAppointments}}</h2>
                        </div>
                    </div>
                </div>
            </div>

            <h3>Próximos Agendamentos</h3>
            {{#upcomingAppointments}}
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">{{service_name}}</h5>
                        <p class="card-text">
                            <strong>Cliente:</strong> {{cliente_name}}<br>
                            <strong>Data/Hora:</strong> <span class="badge bg-info">{{appointment_date}}</span>
                        </p>
                    </div>
                </div>
            {{/upcomingAppointments}}

            {{^upcomingAppointments}}
                <div class="alert alert-info">
                    Não há agendamentos programados para breve.
                </div>
            {{/upcomingAppointments}}
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Ações Rápidas</h5>
                    <a href="/services/create" class="btn btn-primary w-100 mb-2">Novo Serviço</a>
                    <a href="/appointments/prestador-appointments" class="btn btn-secondary w-100 mb-2">Ver Agendamentos</a>
                    <a href="/services" class="btn btn-outline-primary w-100">Meus Serviços</a>
                </div>
            </div>
        </div>
    </div>
</div>

