<div class="container">
    <div class="row">
        <div class="col-md-8">
            <h1>Bem-vindo, {{user.name}}!</h1>

            <div class="row">
                <div class="col-md-6">
                    <div class="card text-center mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Meus Agendamentos</h5>
                            <h2 class="text-primary">{{totalAppointments}}</h2>
                        </div>
                    </div>
                </div>
            </div>

            <h3>Próximos Agendamentos</h3>
            {{#upcomingAppointments}}
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">{{service_name}}</h5>
                        <p class="card-text">
                            <strong>Prestador:</strong> {{prestador_name}}<br>
                            <strong>Data/Hora:</strong> {{appointment_date}}
                        </p>
                    </div>
                </div>
            {{/upcomingAppointments}}

            {{^upcomingAppointments}}
                <div class="alert alert-info">
                    Você não possui agendamentos próximos.
                </div>
            {{/upcomingAppointments}}
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Ações Rápidas</h5>
                    <a href="/services" class="btn btn-primary w-100 mb-2">Buscar Serviços</a>
                    <a href="/appointments/my-appointments" class="btn btn-secondary w-100">Ver Todos os Agendamentos</a>
                </div>
            </div>
        </div>
    </div>
</div>

