<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <strong>📅 AgendaFácil</strong>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/servicos">Serviços</a>
                    </li>
                    {{#usuario}}
                        {{#isCliente}}
                            <li class="nav-item">
                                <a class="nav-link" href="/painel/cliente">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/agendamentos/meus-agendamentos">Meus Agendamentos</a>
                            </li>
                        {{/isCliente}}
                        {{#isPrestador}}
                            <li class="nav-item">
                                <a class="nav-link" href="/painel/prestador">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/servicos/criar">Novo Serviço</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/agendamentos/agendamentos-prestador">Agendamentos</a>
                            </li>
                        {{/isPrestador}}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userMenu" role="button" data-bs-toggle="dropdown">
                                {{usuario.nome}}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                <li><a class="dropdown-item" href="/autenticacao/sair">Sair</a></li>
                            </ul>
                        </li>
                    {{/usuario}}
                    {{^usuario}}
                        <li class="nav-item">
                            <a class="nav-link" href="/autenticacao/entrar">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/autenticacao/cadastro">Cadastro</a>
                        </li>
                    {{/usuario}}
                </ul>
            </div>
        </div>
    </nav>

    <main class="py-4">
        {{{body}}}
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-5">
        <div class="container">
            <p>&copy; 2024 AgendaFácil - Sistema de Agendamento. Todos os direitos reservados.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
