<div class="container">
    <div class="row">
        <div class="col-md-12">
            <h1>Serviços Disponíveis</h1>
            <p class="lead">Encontre e agende os serviços que você procura</p>

            {{#servicos}}
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <h5 class="card-title">{{nome}}</h5>
                                <p class="card-text">{{descricao}}</p>
                                <small class="text-muted">
                                    <strong>Prestador:</strong> {{prestador.nome}}<br>
                                    <strong>Categoria:</strong> {{categoria.nome}}<br>
                                    <strong>Duração:</strong> {{duracao}} minutos
                                </small>
                            </div>
                            <div class="col-md-4 text-end">
                                <h4 class="text-success mb-3">R$ {{preco}}</h4>
                                <a href="/servicos/{{id}}" class="btn btn-primary">Ver Detalhes</a>
                            </div>
                        </div>
                    </div>
                </div>
            {{/servicos}}

            {{^servicos}}
                <div class="alert alert-info">
                    Nenhum serviço disponível no momento.
                </div>
            {{/servicos}}
        </div>
    </div>
</div>
